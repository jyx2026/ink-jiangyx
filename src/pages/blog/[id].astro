---
// src/pages/blog/[id].astro
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// 1. 在生成路径时，计算好每篇文章的上一篇和下一篇
export async function getStaticPaths() {
  // 按时间从旧到新排序（这样 index - 1 就是上一篇较旧的，index + 1 就是下一篇较新的）
  const posts = (await getCollection('blog'))
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

  return posts.map((post, index) => {
    const prevPost = index > 0 ? posts[index - 1] : null;
    const nextPost = index < posts.length - 1 ? posts[index + 1] : null;

    return {
      params: { id: post.id },
      props: { post, prevPost, nextPost },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - 蒋音象`}>
  <article class="py-12">
    <header class="mb-8 border-b border-stone-200 dark:border-stone-800 pb-6">
      <h1 class="text-3xl md:text-4xl font-serif font-bold mb-4 text-stone-950 dark:text-stone-50 leading-tight">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-stone-400">
        <time>{new Date(post.data.pubDate).toLocaleDateString('zh-CN')}</time>
        {post.data.tags && (
          <div class="flex gap-2">
            {post.data.tags.map(tag => (
              <span class="bg-stone-200 dark:bg-stone-800 text-stone-600 dark:text-stone-300 px-2 py-0.5 rounded text-xs">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="prose prose-stone dark:prose-invert max-w-none 
                prose-headings:font-serif prose-headings:font-bold 
                prose-p:leading-relaxed prose-p:text-stone-700 dark:prose-p:text-stone-300 mb-12">
      <Content />
    </div>

    <nav class="grid grid-cols-1 sm:grid-cols-2 gap-4 border-t border-stone-200 dark:border-stone-800 pt-8 mt-8 text-sm">
      <div>
        {prevPost ? (
          <a href={`/blog/${prevPost.id}`} class="block p-4 rounded-xl border border-stone-200 dark:border-stone-800 hover:border-amber-500 dark:hover:border-amber-500 transition-colors group">
            <span class="text-xs text-stone-400 block mb-1">&larr; 上一篇</span>
            <span class="font-serif font-bold text-stone-800 dark:text-stone-200 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors line-clamp-1">{prevPost.data.title}</span>
          </a>
        ) : (
          <div class="p-4 rounded-xl border border-dashed border-stone-200 dark:border-stone-800 text-stone-400 text-xs flex items-center justify-center h-full">
            这是第一篇文章
          </div>
        )}
      </div>

      <div>
        {nextPost ? (
          <a href={`/blog/${nextPost.id}`} class="block p-4 rounded-xl border border-stone-200 dark:border-stone-800 hover:border-amber-500 dark:hover:border-amber-500 transition-colors group text-right">
            <span class="text-xs text-stone-400 block mb-1">下一篇 &rarr;</span>
            <span class="font-serif font-bold text-stone-800 dark:text-stone-200 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors line-clamp-1">{nextPost.data.title}</span>
          </a>
        ) : (
          <div class="p-4 rounded-xl border border-dashed border-stone-200 dark:border-stone-800 text-stone-400 text-xs flex items-center justify-center h-full">
            这是最后一篇文章
          </div>
        )}
      </div>
    </nav>
  </article>
</Layout>