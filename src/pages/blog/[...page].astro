---
// src/pages/blog/[page].astro
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. 导出 getStaticPaths 函数处理分页
export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  // 每页固定显示 5 篇文章
  return paginate(posts, { pageSize: 5 });
}

// 2. 获取分页数据
const { page } = Astro.props;
---

<Layout title={`文章 - 第 ${page.currentPage} 页 - 蒋音象`}>
  <div class="py-12">
    <h1 class="text-3xl font-serif font-bold mb-4 tracking-widest text-stone-900 dark:text-stone-50">
      墨池随笔
    </h1>
    <p class="text-stone-500 dark:text-stone-400 mb-12 text-sm">
      这里记录了我对书法的理解、心得以及日常生活点滴。
    </p>

    <div class="space-y-8 mb-16">
      {page.data.map(post => (
        <article class="border-b border-stone-200 dark:border-stone-800 pb-8">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-3">
            <a href={`/blog/${post.id}`} class="text-2xl font-serif font-bold hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
              {post.data.title}
            </a>
            <time class="text-sm text-stone-400">
              {new Date(post.data.pubDate).toLocaleDateString('zh-CN')}
            </time>
          </div>
          <p class="text-stone-600 dark:text-stone-400 leading-relaxed mb-4">
            {post.data.description}
          </p>
          <a href={`/blog/${post.id}`} class="text-sm font-medium text-amber-600 dark:text-amber-400 hover:underline">
            阅读全文 &rarr;
          </a>
        </article>
      ))}
    </div>

    <nav class="flex justify-between items-center border-t border-stone-200 dark:border-stone-800 pt-6">
      <div>
        {page.url.prev ? (
          <a href={page.url.prev} class="px-4 py-2 border border-stone-300 dark:border-stone-700 rounded-xl hover:bg-stone-100 dark:hover:bg-stone-800 text-sm font-medium transition-colors">&larr; 上一页</a>
        ) : (
          <span class="px-4 py-2 text-stone-400 dark:text-stone-600 text-sm font-medium cursor-not-allowed">&larr; 上一页</span>
        )}
      </div>

      <span class="text-sm text-stone-500">{page.currentPage} / {page.lastPage}</span>

      <div>
        {page.url.next ? (
          <a href={page.url.next} class="px-4 py-2 border border-stone-300 dark:border-stone-700 rounded-xl hover:bg-stone-100 dark:hover:bg-stone-800 text-sm font-medium transition-colors">下一页 &rarr;</a>
        ) : (
          <span class="px-4 py-2 text-stone-400 dark:text-stone-600 text-sm font-medium cursor-not-allowed">下一页 &rarr;</span>
        )}
      </div>
    </nav>
  </div>
</Layout>