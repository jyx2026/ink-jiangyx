---
// src/pages/projects.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 获取所有作品
const projects = await getCollection('projects');
---

<Layout title="作品 - 蒋音象">
  <div class="py-12">
    <h1 class="text-3xl font-serif font-bold mb-4 tracking-widest text-stone-900 dark:text-stone-50">
      笔墨纵横
    </h1>
    <p class="text-stone-500 dark:text-stone-400 mb-12 text-sm">
      这里记录了我日常临帖与创作的书法作品。
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map(project => (
        <div class="group bg-stone-100 dark:bg-stone-800/40 border border-stone-200/60 dark:border-stone-700/50 rounded-2xl overflow-hidden shadow-sm">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={project.data.image} alt={project.data.title} class="project-image w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 cursor-zoom-in" />
          </div>
          <div class="p-6">
            <h2 class="text-xl font-serif font-bold mb-2">{project.data.title}</h2>
            <p class="text-stone-600 dark:text-stone-400 text-sm mb-4 leading-relaxed">{project.data.description}</p>
            <div class="text-xs text-stone-400">
              创作于：{new Date(project.data.pubDate).toLocaleDateString('zh-CN')}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <div id="lightbox" class="fixed inset-0 z-50 hidden bg-black/95 items-center justify-center overflow-hidden cursor-grab">
    <button id="lightbox-close" class="absolute top-6 right-6 text-stone-400 hover:text-white transition-colors z-50 p-2" aria-label="关闭">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>
    <img id="lightbox-img" src="" alt="放大查看" class="max-w-none transform transition-transform duration-75 ease-out pointer-events-none select-none" />
  </div>
  <script is:inline>
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const closeBtn = document.getElementById('lightbox-close');
    const triggers = document.querySelectorAll('.project-image');

    let isDragging = false;
    let startX, startY;
    let translateX = 0, translateY = 0;
    let scale = 1.2; // 默认稍微放大一点，方便拖拽查看

    // 更新图片的位移和缩放
    const updateTransform = () => {
      lightboxImg.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
    };

    // 1. 点击作品：打开弹窗
    triggers.forEach(img => {
      img.addEventListener('click', (e) => {
        lightboxImg.src = e.target.src;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        
        // 重置位置和缩放
        translateX = 0;
        translateY = 0;
        scale = 1.2; 
        updateTransform();
      });
    });

    // 2. 关闭弹窗的逻辑
    const closeLightbox = () => {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
    };
    
    closeBtn.addEventListener('click', closeLightbox); // 点击 X 关闭
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox(); // 点击黑色的背景区域也关闭
    });

    // 3. 鼠标拖动逻辑
    lightbox.addEventListener('mousedown', (e) => {
      if (e.target === closeBtn) return; // 避开关闭按钮
      isDragging = true;
      startX = e.clientX - translateX;
      startY = e.clientY - translateY;
      lightbox.classList.add('cursor-grabbing'); // 鼠标变成抓取手势
    });

    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      translateX = e.clientX - startX;
      translateY = e.clientY - startY;
      updateTransform();
    });

    window.addEventListener('mouseup', () => {
      isDragging = false;
      lightbox.classList.remove('cursor-grabbing');
    });

    // 4. 鼠标滚轮缩放逻辑 (支持缩小和放大)
    lightbox.addEventListener('wheel', (e) => {
      e.preventDefault();
      // 调整缩放速度
      scale += e.deltaY * -0.0015;
      // 限制缩放的极限值 (0.5倍 到 4倍)
      scale = Math.min(Math.max(0.5, scale), 4); 
      updateTransform();
    }, { passive: false });
  </script>
</Layout>