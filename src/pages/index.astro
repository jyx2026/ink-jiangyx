---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. 获取精选作品（最多5幅）
const featuredProjects = (await getCollection('projects'))
  .filter(project => project.data.featured)
  .slice(0, 5);

// 2. 获取最新博文（按时间倒序，最多3篇）
const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Layout title="蒋音象 - 以文会友，以友辅仁">
  <section class="flex flex-col items-center justify-center py-20 text-center">
    <div class="w-28 h-28 rounded-full bg-stone-300 dark:bg-stone-800 overflow-hidden shadow-xl mb-6 border-4 border-white dark:border-stone-700">
      <img src="/images/avatar.webp" alt="我的头像" class="w-full h-full object-cover" />
    </div>
    <h1 class="text-3xl md:text-5xl font-serif font-bold mb-4 tracking-widest text-stone-900 dark:text-stone-50">
      字如其人，见字如面
    </h1>
    <p class="text-stone-600 dark:text-stone-400 mb-8 max-w-md text-sm md:text-base">
      书法是中国文化根脉的第一审美形态
    </p>
    <a href="/about" class="px-6 py-2.5 border border-stone-800 dark:border-stone-200 rounded-full hover:bg-stone-800 hover:text-white dark:hover:bg-stone-200 dark:hover:text-stone-900 transition-all duration-300 text-sm font-medium">
      了解更多
    </a>
  </section>

  <section class="py-12 border-t border-stone-200 dark:border-stone-800">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-xl font-serif font-bold tracking-wider flex items-center gap-2">
        <span class="w-1.5 h-6 bg-amber-600 dark:bg-amber-500 rounded-full"></span>
        精选作品
      </h2>
      <a href="/projects" class="text-sm text-stone-500 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
        全部作品 &rarr;
      </a>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {featuredProjects.map(project => (
        <div class="group relative bg-stone-100 dark:bg-stone-800/50 rounded-2xl overflow-hidden border border-stone-200/60 dark:border-stone-700/50 shadow-sm hover:shadow-md transition-all duration-300">
          <div class="aspect-[4/3] w-full overflow-hidden bg-stone-200 dark:bg-stone-800">
            <img 
              src={project.data.image} 
              alt={project.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6">
            <h3 class="text-lg font-serif font-bold mb-2 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
              {project.data.title}
            </h3>
            <p class="text-stone-600 dark:text-stone-400 text-sm line-clamp-2 leading-relaxed">
              {project.data.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-12 border-t border-stone-200 dark:border-stone-800">
    <div class="flex justify-between items-center mb-8">
      <h2 class="text-xl font-serif font-bold tracking-wider flex items-center gap-2">
        <span class="w-1.5 h-6 bg-amber-600 dark:bg-amber-500 rounded-full"></span>
        最新博文
      </h2>
      <a href="/blog" class="text-sm text-stone-500 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
        全部文章 &rarr;
      </a>
    </div>

    <div class="space-y-6">
      {latestPosts.map(post => (
        <a href={`/blog/${post.id}`} class="block p-6 rounded-2xl border border-stone-200/60 dark:border-stone-700/50 bg-stone-50/50 dark:bg-stone-800/20 hover:bg-stone-100 dark:hover:bg-stone-800/40 transition-all duration-300">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-2">
            <h3 class="text-lg font-serif font-bold text-stone-900 dark:text-stone-100">
              {post.data.title}
            </h3>
            <time class="text-xs text-stone-400">
              {new Date(post.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <p class="text-stone-600 dark:text-stone-400 text-sm leading-relaxed line-clamp-2">
            {post.data.description}
          </p>
        </a>
      ))}
    </div>
  </section>
</Layout>